{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "../linkly-frontend/src/components/EditLinkModal.tsx"]
}